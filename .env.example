# ─── LLM Provider ───────────────────────────────────────────────
# Choose your provider: "gemini", "nvidia", "openai", "groq"
LLM_PROVIDER=nvidia

# Set the API key for your chosen provider
NVIDIA_API_KEY=your-nvidia-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# GROQ_API_KEY=your-groq-api-key-here

# ─── Model Selection (optional) ────────────────────────────────
# Fast model: used for Stage 1 (intent extraction) — optimized for speed
FAST_MODEL=moonshotai/kimi-k2.6

# Analytical model: used for Stages 2-4 — optimized for reasoning quality
ANALYTICAL_MODEL=moonshotai/kimi-k2.6

# ─── Pipeline Configuration (optional) ─────────────────────────
MAX_REPAIR_CYCLES=3
PIPELINE_TIMEOUT_SECONDS=600

# ─── Web Server (optional) ─────────────────────────────────────
PORT=8000
